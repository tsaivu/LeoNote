VPS_HOST=your-vps-ip
VPS_PORT=22
VPS_USER=root
VPS_DIR=/opt/leonote
SSH_IDENTITY_FILE=

DEPLOY_DOMAIN=tasks.example.com
APP_HTTP_PORT=9120
LETSENCRYPT_EMAIL=admin@example.com

POSTGRES_DB=leonote
POSTGRES_USER=leonote_user
POSTGRES_PASSWORD=generate-a-strong-password
JWT_SECRET_KEY=generate-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
APP_TIMEZONE=Asia/Ho_Chi_Minh
VITE_API_BASE_URL=/api

SEED_USERNAME=your-initial-username
SEED_PASSWORD=your-initial-password
SEED_DISPLAY_NAME=YourDisplayName
SEED_ENFORCE_SINGLE_USER=true
ALLOW_REGISTRATION=false
