POSTGRES_DB=personal_notes
POSTGRES_USER=personal_notes_user
POSTGRES_PASSWORD=change-this-postgres-password

JWT_SECRET_KEY=change-this-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ORIGINS=https://notes.example.com
COOKIE_SECURE=true
COOKIE_DOMAIN=notes.example.com

VITE_API_BASE_URL=/api
APP_HTTP_PORT=9120

SEED_USERNAME=change-this-seed-username
SEED_PASSWORD=change-this-seed-password
SEED_DISPLAY_NAME=Change This Display Name
SEED_ENFORCE_SINGLE_USER=true
ALLOW_REGISTRATION=false
